<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="org.gnome.calculator.CurrencyDisplay">
    <value value="0" nick="code"/>
    <value value="1" nick="name"/>
    <value value="2" nick="both"/>
  </enum>
  
  <schema path="/org/gnome/calculator/" id="org.gnome.calculator" gettext-domain="gnome-calculator">
    <key name="currency-display" enum="org.gnome.calculator.CurrencyDisplay">
      <default>'name'</default>
    </key>
    <key type="as" name="favorite-currencies">
      <default>[]</default>
    </key>
  </schema>
  
  <schema id="org.gnome.TextEditor" path="/org/gnome/TextEditor/">
    <key name="show-line-numbers" type="b">
      <default>false</default>
    </key>
    <key name="spellcheck" type="b">
      <default>false</default>
    </key>
    <key name="wrap-text" type="b">
      <default>false</default>
    </key>
  </schema>
  
  <schema path="/net/nokyan/Resources/" id="net.nokyan.Resources" gettext-domain="resources">
    <key name="processes-show-user" type="b">
      <default>false</default>
    </key>
    <key name="show-virtual-network-interfaces" type="b">
      <default>false</default>
    </key>
    <key name="sidebar-description" type="b">
      <default>false</default>
    </key>
    <key name="sidebar-details" type="b">
      <default>false</default>
    </key>
  </schema>
</schemalist>
