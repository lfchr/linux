#!/usr/bin/env bash

set -ex

schemas=(
    'org.gnome.shell app-picker-layout'
    'org.gnome.desktop.app-folders folder-children'
    'org.gnome.settings-daemon.plugins.power idle-dim'
    'org.gnome.settings-daemon.plugins.power sleep-inactive-ac-timeout'
    'org.gnome.desktop.session idle-delay'
    'org.gnome.nautilus.preferences default-folder-viewer'
    'org.gnome.nautilus.list-view default-zoom-level'
    'org.gnome.nautilus.list-view default-visible-columns'
    'org.gnome.nautilus.list-view default-column-order'
    'org.gtk.gtk4.Settings.FileChooser show-hidden'
    'org.gtk.gtk4.Settings.FileChooser sort-directories-first'
    'org.gtk.Settings.FileChooser show-hidden'
    'org.gtk.Settings.FileChooser sort-directories-first'
)

for schema in ${schemas[@]}; do
    gsettings reset "$schema"
done
