[Unit]
Description=Copy monitor configuration from main user to xdg for gdm
Before=gdm.service

[Service]
ExecCondition=/bin/sh -c 'cat /home/$(id -nu 1000)/.config/monitors.xml'
ExecStart=/bin/sh -c 'cp /home/$(id -nu 1000)/.config/monitors.xml /etc/xdg/monitors.xml'

[Install]
WantedBy=graphical.target
